<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Declare Leanback requirement for Android TV -->
    <uses-feature android:name="android.software.leanback" android:required="true" />
    <!-- Declare Touchscreen is not required (since TV apps use D-pad remotes) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:banner="@drawable/ic_tv_banner"
        android:icon="@drawable/ic_tv_banner"
        android:label="Quicky"
        android:supportsRtl="true"
        android:theme="@style/Theme.Quicky">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Quicky">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- Key TV Requirement: LEANBACK_LAUNCHER makes it show on TV home screen -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
